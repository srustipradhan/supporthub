
DB_HOST=ep-xxxx-pooler.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password
DB_DATABASE=neondb
# DB_SSL=true
# DB_SYNCHRONIZE=true

# --- Local PostgreSQL ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_DATABASE=supporthub
# DB_SSL=false

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

PORT=3000

ADMIN_EMAIL=admin@supporthub.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Admin

# --- Push notifications (required for FCM on device) ---
# Download service account JSON from Firebase Console → Project settings → Service accounts.
# Local: place file as backend/firebase-service-account.json OR set path below.
# Render/production: paste the entire JSON as one line (no line breaks) into the dashboard env var.
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
