# --- Option A: Neon / cloud (recommended for live) ---
# Copy "Connection string" from Neon console → paste below (include ?sslmode=require)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Option B: Neon / Postgres via DB_* (SSL auto-enabled for *.neon.tech) ---
DB_HOST=ep-xxxx-pooler.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password
DB_DATABASE=neondb
# DB_SSL=true
# DB_SYNCHRONIZE=true

# --- Local PostgreSQL ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_DATABASE=supporthub
# DB_SSL=false

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

PORT=3000

ADMIN_EMAIL=admin@supporthub.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Admin
